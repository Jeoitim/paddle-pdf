{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PaddlePDF",
  "version": "1.0.0",
  "identifier": "com.paddlepdf.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PaddlePDF — PDF OCR Tool",
        "width": 900,
        "height": 680,
        "minWidth": 600,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "pyembed/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true
      },
      "wix": null
    },
    "category": "Utility",
    "shortDescription": "PDF OCR tool powered by PaddleOCR",
    "longDescription": "PaddlePDF converts scanned PDFs into searchable PDFs using PaddleOCR. Supports Chinese, English, Japanese, Korean, and Cyrillic text recognition with GPU acceleration.",
    "copyright": "© 2026 PaddlePDF"
  }
}
